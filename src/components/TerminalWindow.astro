---
import { AUTHOR } from '../consts';

interface Props {
  /** 标题栏显示的路径,如 ~/blog */
  path: string;
  /** 进入页面时“执行”的命令,如 ls -l */
  command?: string;
}

const { path, command } = Astro.props;
---

<div class="reveal rounded-xl border border-line bg-surface shadow-2xl overflow-hidden">
  <!-- 窗口标题栏 -->
  <div class="flex items-center gap-2 px-4 h-10 border-b border-line bg-paper/60 select-none">
    <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
    <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
    <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
    <span class="ml-3 text-xs text-muted truncate">visitor@{AUTHOR}: {path}</span>
  </div>
  <div class="term-scanlines relative px-4 sm:px-6 py-5 text-[13px] sm:text-sm leading-relaxed">
    {command && (
      <p class="whitespace-pre-wrap break-words mb-5">
        <span class="t-green t-bold glow-green">visitor@{AUTHOR}</span><span class="t-dim">:</span><span class="t-blue t-bold">{path}</span><span class="t-dim">$</span> {command}
      </p>
    )}
    <slot />
  </div>
</div>
