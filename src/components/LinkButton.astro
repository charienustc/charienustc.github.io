  mail: '<path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/>',
  rss: '<path d="M4 11a9 9 0 0 1 9 9h-2a7 7 0 0 0-7-7zm0-4a13 13 0 0 1 13 13h-2A11 11 0 0 0 4 9zm1.5 8.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"/>',
