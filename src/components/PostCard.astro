---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, tags } = entry.data;
const base = import.meta.env.BASE_URL;
---

<li class="group">
  <a href={`${base}blog/${entry.id}`} class="block py-4 border-b border-zinc-200 dark:border-zinc-800 transition-colors hover:border-zinc-400 dark:hover:border-zinc-600">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
        {title}
      </h3>
      <time class="shrink-0 text-sm text-zinc-500 dark:text-zinc-400">
        {pubDate.toLocaleDateString('zh-CN')}
      </time>
    </div>
    {description && (
      <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400 line-clamp-2">{description}</p>
    )}
    {tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </a>
</li>
