---
import { AUTHOR } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 mt-auto">
  <div class="mx-auto max-w-3xl px-4 py-6 text-sm text-zinc-500 dark:text-zinc-400 flex flex-col sm:flex-row items-center justify-between gap-2">
    <span>© {year} {AUTHOR}</span>
    <span>
      Built with <a href="https://astro.build" class="hover:text-blue-500" target="_blank" rel="noopener">Astro</a>
    </span>
  </div>
</footer>
