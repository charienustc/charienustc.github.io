---
import { SITE_TITLE, NAV_LINKS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === base || pathname === base.replace(/\/$/, '');
  return pathname.startsWith(base + href.replace(/^\//, ''));
}
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-paper/85 border-b border-line font-mono">
  <div class="mx-auto max-w-4xl px-6 h-14 flex items-center justify-between">
    <a href={base} class="text-base whitespace-nowrap text-ink font-['Times_New_Roman',serif]">
      {SITE_TITLE}
    </a>
    <nav class="flex items-center gap-0.5 sm:gap-1 text-sm">
      {NAV_LINKS.map((link) => (
        <a
          href={base + link.href.replace(/^\//, '')}
          class:list={[
            'px-2 sm:px-2.5 py-1.5 transition-colors',
            isActive(link.href)
              ? 't-green t-bold'
              : 'text-ink-soft hover:text-[var(--green)]',
          ]}
        >
          {link.label}
        </a>
      ))}
      <ThemeToggle />
    </nav>
  </div>
</header>
