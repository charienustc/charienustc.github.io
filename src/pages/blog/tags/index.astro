---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TerminalWindow from '../../../components/TerminalWindow.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../../consts';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).filter((p) => !p.data.draft);

const tagCount = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title={`标签 · ${AUTHOR}`} description="全部文章标签">
  <TerminalWindow path="~/blog/tags" command="ls -l">
    {tags.length === 0 ? (
      <p class="t-dim">total 0 —— 暂无标签。</p>
    ) : (
      <>
        <p class="t-dim mb-3">total {tags.length}</p>
        <div class="flex flex-wrap gap-2">
          {tags.map(([tag, count]) => (
            <a
              href={`${base}blog/tags/${tag}`}
              class="px-2.5 py-1 rounded border border-line t-cyan hover:text-[var(--green)] hover:border-[var(--green)] transition-colors"
            >
              #{tag}<span class="t-dim ml-1.5">{count}</span>
            </a>
          ))}
        </div>
      </>
    )}
    <p class="mt-6 text-xs sm:text-sm">
      <a href={`${base}blog`} class="t-cyan link-underline">$ cd ~/blog</a>
      <span class="t-dim ml-4">← 返回文章列表</span>
    </p>
  </TerminalWindow>
</BaseLayout>
