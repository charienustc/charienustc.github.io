---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../../consts';

const posts = (await getCollection('blog')).filter((p) => !p.data.draft);

const tagCount = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`标签 · ${AUTHOR}`} description="全部文章标签">
  <h1 class="text-2xl font-bold mb-6">标签</h1>
  {tags.length === 0 ? (
    <p class="text-zinc-500 dark:text-zinc-400">暂无标签。</p>
  ) : (
    <div class="flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a
          href={`${base}blog/tags/${tag}`}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
        >
          <span>#{tag}</span>
          <span class="text-xs text-zinc-500 dark:text-zinc-400">{count}</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
