---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}

const years = [...byYear.keys()].sort((a, b) => b - a);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`归档 · ${AUTHOR}`} description="按年份归档的文章">
  <h1 class="text-2xl font-bold mb-6">归档</h1>
  {years.map((year) => (
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3 text-zinc-700 dark:text-zinc-300">{year}</h2>
      <ul class="flex flex-col gap-2">
        {byYear.get(year)!.map((post) => (
          <li class="flex items-baseline justify-between gap-4">
            <a
              href={`${base}blog/${post.id}`}
              class="text-zinc-900 dark:text-zinc-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              {post.data.title}
            </a>
            <time class="shrink-0 text-sm text-zinc-500 dark:text-zinc-400">
              {post.data.pubDate.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
            </time>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
