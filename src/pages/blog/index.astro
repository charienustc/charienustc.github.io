---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalWindow from '../../components/TerminalWindow.astro';
import PostRow from '../../components/PostRow.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../consts';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`博客 · ${AUTHOR}`} description={`${AUTHOR} 的博客文章`}>
  <TerminalWindow path="~/blog" command="ls -l">
    {posts.length === 0 ? (
      <p class="t-dim">total 0 —— 还没有文章,敬请期待。</p>
    ) : (
      <>
        <p class="t-dim mb-1">total {posts.length}</p>
        <div class="flex flex-col">
          {posts.map((post) => <PostRow entry={post} />)}
        </div>
      </>
    )}
    <p class="mt-6 text-muted text-xs sm:text-sm">
      <span class="t-dim">相关:</span>
      <a href={`${base}blog/tags`} class="t-cyan link-underline ml-2">ls tags/</a>
      <a href={`${base}blog/archive`} class="t-cyan link-underline ml-3">cat archive.log</a>
    </p>
  </TerminalWindow>
</BaseLayout>
