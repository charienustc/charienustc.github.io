---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalWindow from '../../components/TerminalWindow.astro';
import { getCollection, render } from 'astro:content';
import { AUTHOR } from '../../consts';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, heroImage } = post.data;
const base = import.meta.env.BASE_URL;
const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<BaseLayout title={`${title} · ${AUTHOR}`} description={description} image={heroImage}>
  <TerminalWindow path={`~/blog`} command={`cat ${post.id}.md`}>
    <header class="mb-6">
      <h1 class="t-green t-bold text-lg sm:text-xl whitespace-pre-wrap break-words">{title}</h1>
      <p class="t-dim mt-2 text-xs sm:text-sm">
        {fmt(pubDate)}
        {updatedDate && <span>(更新于 {fmt(updatedDate)})</span>}
        {tags.length > 0 && (
          <span>
            {'  ·  '}
            {tags.map((tag, i) => (
              <>
                <a href={`${base}blog/tags/${tag}`} class="t-cyan link-underline">#{tag}</a>{i < tags.length - 1 ? '  ' : ''}
              </>
            ))}
          </span>
        )}
      </p>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <p class="mt-10 pt-4 border-t border-line text-xs sm:text-sm">
      <a href={`${base}blog`} class="t-cyan link-underline">$ cd ~/blog</a>
      <span class="t-dim ml-4">← 返回文章列表</span>
    </p>
  </TerminalWindow>
</BaseLayout>
