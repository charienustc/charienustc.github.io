---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import { getCollection } from 'astro:content';
import { socials } from '../data/socials';
import { AUTHOR, SITE_DESCRIPTION } from '../consts';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.order - a.data.order);

const fmtDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;

const termData = {
  author: AUTHOR,
  description: SITE_DESCRIPTION,
  base,
  posts: posts.map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    date: fmtDate(p.data.pubDate),
    tags: p.data.tags,
    excerpt: (p.body ?? '')
      .split('\n')
      .filter((l) => l.trim() !== '')
      .slice(0, 6)
      .join('\n'),
  })),
  projects: projects.map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    url: p.data.url ?? null,
    repo: p.data.repo ?? null,
  })),
  socials: socials.map((s) => ({ name: s.name, url: s.url, handle: s.handle ?? '' })),
};
---

<BaseLayout>
  <div class="reveal mb-5">
    <p class="text-xs sm:text-sm text-muted">
      <span class="t-green">➜</span> ~/index.html — interactive shell · 这是一个真正可用的终端,不是摆设
    </p>
  </div>

  <Terminal data={termData} />

  <!-- 无 JS / 不想用命令时的直达入口(也有利于 SEO) -->
  <div class="reveal mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-muted" style="animation-delay:150ms">
    <span class="t-dim">直达:</span>
    <a href={`${base}blog`} class="t-cyan link-underline">博客 →</a>
    <a href={`${base}portfolio`} class="t-cyan link-underline">作品集 →</a>
    <a href={`${base}links`} class="t-cyan link-underline">链接 →</a>
  </div>
  <noscript>
    <p class="mt-4 text-sm t-yellow">
      当前浏览器禁用了 JavaScript,终端无法运行。请直接访问:
      <a href={`${base}blog`} class="t-cyan underline">博客</a> ·
      <a href={`${base}portfolio`} class="t-cyan underline">作品集</a> ·
      <a href={`${base}links`} class="t-cyan underline">链接</a>
    </p>
  </noscript>
</BaseLayout>
