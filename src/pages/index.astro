---
import BaseLayout from '../layouts/BaseLayout.astro';
import { socials } from '../data/socials';
import { AUTHOR, SITE_DESCRIPTION } from '../consts';

const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <section class="flex flex-col items-center gap-6 py-10 text-center">
    <img
      src={base + 'avatar.jpg'}
      alt="头像"
      class="w-32 h-32 rounded-full object-cover ring-4 ring-zinc-200 dark:ring-zinc-800"
      onerror="this.style.display='none'"
    />
    <h1 class="text-3xl font-bold tracking-tight">{AUTHOR}</h1>
    <p class="max-w-prose text-zinc-600 dark:text-zinc-400 leading-relaxed">
      {SITE_DESCRIPTION}
    </p>
    <div class="flex flex-wrap justify-center gap-x-5 gap-y-2">
      {socials.slice(0, 6).map((s) => (
        <a
          href={s.url}
          target={s.url.startsWith('http') ? '_blank' : undefined}
          rel={s.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          {s.name}
        </a>
      ))}
    </div>
  </section>

  <section class="mt-8 grid gap-4 sm:grid-cols-2">
    <a href={base + 'portfolio'} class="rounded-xl border border-zinc-200 dark:border-zinc-800 p-5 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors">
      <h2 class="font-semibold text-lg">作品集 →</h2>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">我做过的一些项目</p>
    </a>
    <a href={base + 'blog'} class="rounded-xl border border-zinc-200 dark:border-zinc-800 p-5 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors">
      <h2 class="font-semibold text-lg">博客 →</h2>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">想法、笔记与文章</p>
    </a>
  </section>
</BaseLayout>
