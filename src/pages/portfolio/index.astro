---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalWindow from '../../components/TerminalWindow.astro';
import { getCollection } from 'astro:content';
import { AUTHOR } from '../../consts';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout title={`作品集 · ${AUTHOR}`} description={`${AUTHOR} 的项目与作品`}>
  <TerminalWindow path="~/projects" command="ls -l && cat *.summary">
    {projects.length === 0 ? (
      <p class="t-dim">total 0 —— 还没有展示的项目。</p>
    ) : (
      <>
        <p class="t-dim mb-4">total {projects.length}</p>
        <div class="flex flex-col gap-6">
          {projects.map((p) => (
            <div class="border-l-2 border-line pl-4">
              <p class="whitespace-pre-wrap break-words">
                <span class="t-cyan t-bold">{p.id}.md</span>
                {p.data.featured && <span class="t-yellow ml-2" title="精选">★</span>}
              </p>
              <p class="t-green mt-1"># {p.data.title}</p>
              <p class="text-ink-soft mt-1">{p.data.description}</p>
              {p.data.tags.length > 0 && (
                <p class="t-dim mt-1 text-xs sm:text-sm">{p.data.tags.map((t) => '#' + t).join('  ')}</p>
              )}
              <p class="mt-1.5 text-xs sm:text-sm">
                {p.data.repo && (
                  <a href={p.data.repo} target="_blank" rel="noopener" class="t-cyan link-underline">repo →</a>
                )}
                {p.data.url && (
                  <a href={p.data.url} target="_blank" rel="noopener" class="t-cyan link-underline ml-3">url →</a>
                )}
              </p>
            </div>
          ))}
        </div>
      </>
    )}
  </TerminalWindow>
</BaseLayout>
