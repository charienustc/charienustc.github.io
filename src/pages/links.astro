---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.astro';
import { socials } from '../data/socials';
import { AUTHOR } from '../consts';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`链接 · ${AUTHOR}`} description="我的所有平台链接">
  <div class="flex flex-col items-center gap-6 py-8">
    <img
      src={base + 'avatar.jpg'}
      alt="头像"
      class="w-24 h-24 rounded-full object-cover ring-4 ring-zinc-200 dark:ring-zinc-800"
      onerror="this.style.display='none'"
    />
    <div class="text-center">
      <h1 class="text-xl font-bold">{AUTHOR}</h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm mt-1">所有链接集中于此</p>
    </div>
    <div class="w-full max-w-sm flex flex-col gap-3">
      {socials.map((social) => <LinkButton social={social} />)}
    </div>
  </div>
</BaseLayout>
