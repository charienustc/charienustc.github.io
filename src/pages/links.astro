---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import { socials } from '../data/socials';
import { AUTHOR } from '../consts';
---

<BaseLayout title={`链接 · ${AUTHOR}`} description="我的所有平台链接">
  <TerminalWindow path="~" command="cat links.txt">
    <p class="t-green t-bold mb-1"># 各平台链接</p>
    <p class="t-dim mb-5"># 点击即可跳转</p>
    <div class="flex flex-col">
      {socials.map((s) => {
        const isExternal = !s.url.startsWith('/') && !s.url.startsWith('#');
        return (
          <a
            href={s.url}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
            class="group whitespace-pre-wrap break-words py-2 -mx-2 px-2 rounded hover:bg-paper/60 transition-colors"
          >
            <span class="t-green">{s.name.padEnd(10)}</span>
            <span class="t-dim"> →  </span>
            <span class="t-cyan group-hover:underline underline-offset-4">{s.url}</span>
            {s.handle && <span class="t-dim">  ({s.handle})</span>}
            {isExternal && <span class="t-dim opacity-0 group-hover:opacity-100 transition-opacity"> ↗</span>}
          </a>
        );
      })}
    </div>
    <p class="mt-6 t-dim text-xs sm:text-sm"># EOF</p>
  </TerminalWindow>
</BaseLayout>
